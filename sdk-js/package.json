    "directory": "sdk-js"
  },
  "bugs": {
    "url": "https://github.com/Jake1848/conduit/issues"
  },
  "keywords": ["bitcoin", "lightning", "ai-agents", "payments", "lnd", "self-hosted", "non-custodial", "conduit"],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^20.11.0"
  }
