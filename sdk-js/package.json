      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test tests/*.test.mjs",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/Jake1848/conduit#readme",
