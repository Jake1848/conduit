CONDUIT_ENV=development
CONDUIT_NETWORK=testnet

# Development: SQLite at ./data/conduit.db
DATABASE_URL=sqlite+aiosqlite:///./data/conduit.db
# Production: Postgres via asyncpg (REQUIRED — SQLite is rejected at startup).
#   DATABASE_URL=postgresql+asyncpg://conduit:strong-pw@localhost:5432/conduit

# Generate with: openssl rand -hex 32
# Used as the HMAC key for X-Conduit-Server-Signature on outbound webhooks.
# Production refuses to start if this is left as the default.
API_SECRET_KEY=change-me-to-a-64-char-random-string

LOG_LEVEL=info

LND_MOCK=true
LND_REST_URL=https://127.0.0.1:8080
LND_MACAROON_PATH=/root/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
LND_TLS_CERT_PATH=/root/.lnd/tls.cert

# Installs an initial admin API key on a fresh DB. Required in production.
BOOTSTRAP_API_KEY=ck_test_dev_root

# CORS allowlist (comma-separated). Empty = no cross-origin requests.
#   ALLOWED_ORIGINS=https://conduit.energy,https://app.conduit.energy
ALLOWED_ORIGINS=

# In-process HTTP rate limit. Set to 0 to disable.
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_BURST=60
