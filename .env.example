# Conduit — self-hosted, non-custodial config.
# Copy to .env and fill in the values below, then: docker compose up -d
#
#   cp .env.example .env
#
# Your node, your keys, your rules. Conduit never holds your funds — it talks to
# YOUR LND node and records the platform fee + per-agent balances in Postgres.

# ---- Your LND node --------------------------------------------------------
# Point this at YOUR LND node's REST endpoint. Use host.docker.internal for an
# LND running on this same host, or an IP/hostname for a remote node.
# Drop the node's admin.macaroon and tls.cert into ./secrets/ (see QUICKSTART.md).
LND_REST_URL=https://host.docker.internal:8080

# Network your LND runs on: mainnet | testnet | signet | regtest
CONDUIT_NETWORK=mainnet

# ---- Secrets — generate fresh values, never commit them -------------------
# Admin API key that bootstraps the first key on a fresh DB. The prefix must
# match CONDUIT_NETWORK: ck_live_ on mainnet, ck_test_ on testnet/signet/regtest.
#   mainnet: BOOTSTRAP_API_KEY=ck_live_$(openssl rand -hex 20)
#   testnet: BOOTSTRAP_API_KEY=ck_test_$(openssl rand -hex 20)
BOOTSTRAP_API_KEY=ck_live_REPLACE_ME

# HMAC key for signing outbound webhooks. Production refuses the dev default.
#   openssl rand -hex 32
API_SECRET_KEY=REPLACE_ME

# Postgres password for the bundled ledger database.
#   openssl rand -hex 24
POSTGRES_PASSWORD=REPLACE_ME

# ---- Platform fee — YOUR per-transaction revenue (in sats) ----------------
# A small usage-based fee charged on top of each outbound payment: a percentage
# of the amount, clamped to [min, max] sats. Kept by you on settle, refunded in
# full on failure. Set PLATFORM_FEE_PERCENT=0 to turn it off.
PLATFORM_FEE_PERCENT=0.5
PLATFORM_FEE_MIN_SATS=1
PLATFORM_FEE_MAX_SATS=1000

# ---- Optional -------------------------------------------------------------
# CORS allowlist (comma-separated). Empty = same-origin only.
#   ALLOWED_ORIGINS=https://console.conduit.energy
ALLOWED_ORIGINS=

LOG_LEVEL=info
