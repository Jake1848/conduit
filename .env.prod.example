# Copy to .env.prod and fill in real values.
# `docker compose -f docker-compose.prod.yml --env-file .env.prod up -d`

# Postgres
POSTGRES_PASSWORD=

# Conduit secrets — generate fresh values
# openssl rand -hex 32      → API_SECRET_KEY
# ck_live_$(openssl rand -hex 20)  → BOOTSTRAP_API_KEY
API_SECRET_KEY=
BOOTSTRAP_API_KEY=

# Network: mainnet | testnet | signet | regtest
CONDUIT_NETWORK=mainnet

# CORS — comma-separated origins. Leave empty for no cross-origin.
ALLOWED_ORIGINS=https://conduit.energy,https://app.conduit.energy

# In-process HTTP rate limit (per worker).
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_BURST=60

# Reach the host's LND REST. Override if LND runs in a different network.
LND_REST_URL=https://host.docker.internal:8080

LOG_LEVEL=info
