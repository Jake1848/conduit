# Conduit API base URL. The dashboard talks to this directly from the browser,
# so the API's ALLOWED_ORIGINS must include this app's origin (CORS).
#
# Regtest sandbox (local dev) — if the API is bound to localhost on a remote
# host, reach it with an SSH tunnel (substitute your own host/user/key):
#   ssh -i ~/.ssh/your_key -L 8002:localhost:8002 your-ssh-user@YOUR_SERVER_IP -N
NEXT_PUBLIC_API_URL=http://localhost:8002

# Testnet (public) — for a deployed build. The testnet API must allow this
# deployment's origin in ALLOWED_ORIGINS.
# NEXT_PUBLIC_API_URL=https://api.conduit.energy
