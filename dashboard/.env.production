# Production build target — the public TESTNET API (api.conduit.energy, v0.6.0).
# This is the default the Vercel production build uses. A Vercel project env var
# NEXT_PUBLIC_API_URL (if set) OVERRIDES this, so to switch environments either
# edit this file or the Vercel env var (keep them in agreement).
# Local dev still uses .env.local (regtest sandbox via the SSH tunnel).
NEXT_PUBLIC_API_URL=https://api.conduit.energy
